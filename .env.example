# Application
APP_ENV=development
APP_PORT=8080

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Optional: service role for future admin routes (not used by /me)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: verify HS256 project JWTs locally (not required when using auth/v1/user)
SUPABASE_JWT_SECRET=

# CORS — comma-separated SPA origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4321

# Oracle / cloud-init (production bootstrap only)
GIT_REPO_URL=
GIT_BRANCH=main
